#!/usr/bin/env python3
from __future__ import annotations

import argparse
import os
import re
import shutil
from pathlib import Path

SCRIPT_PATH = Path(__file__).resolve()
PLUGIN_HOME = SCRIPT_PATH.parent.parent
SECTION_RE = re.compile(r"<!--\s*(SHARED|AGENTS|CLAUDE):START\s*-->(.*?)<!--\s*\1:END\s*-->", re.DOTALL)


def parse_manifest(path: Path) -> dict[str, str]:
    data: dict[str, str] = {}
    for raw_line in path.read_text(encoding="utf-8").splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#"):
            continue
        key, sep, value = line.partition(":")
        if not sep:
            raise SystemExit(f"invalid manifest line in {path}: {raw_line}")
        data[key.strip()] = value.strip()
    return data


def render_sections(root_text: str) -> dict[str, str]:
    sections = {match.group(1): match.group(2).strip() for match in SECTION_RE.finditer(root_text)}
    required = {"SHARED", "AGENTS", "CLAUDE"}
    missing = required - sections.keys()
    if missing:
        raise SystemExit("root.md is missing sections: " + ", ".join(sorted(missing)))
    return sections


def replace_placeholders(text: str, project_name: str, project_root: Path) -> str:
    return text.replace("{{PROJECT_NAME}}", project_name).replace("{{PROJECT_ROOT}}", str(project_root))


def replace_file(path: Path, content: str, force: bool) -> None:
    if path.exists() or path.is_symlink():
        if not force:
            raise SystemExit(f"refusing to overwrite existing path without --force: {path}")
        if path.is_dir() and not path.is_symlink():
            raise SystemExit(f"refusing to replace directory: {path}")
        path.unlink()
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content.rstrip() + "\n", encoding="utf-8")


def install_root(args: argparse.Namespace) -> None:
    manifest = parse_manifest(PLUGIN_HOME / "plugins" / "root" / "plugin.yaml")
    project_root = Path(args.project_root).expanduser().resolve()
    project_name = args.project_name or project_root.name
    source_path = PLUGIN_HOME / manifest["source"]
    sections = render_sections(source_path.read_text(encoding="utf-8"))

    agents_body = replace_placeholders(sections["SHARED"] + "\n\n" + sections["AGENTS"], project_name, project_root)
    claude_body = replace_placeholders(sections["SHARED"] + "\n\n" + sections["CLAUDE"], project_name, project_root)

    agents_doc = (
        "# AGENTS.md\n\n"
        "`agent-plugin`으로 생성된 파일입니다. 장기 수정은 `agent-plugins/roots/root.md`에서 관리하세요.\n\n"
        + agents_body
    )
    claude_doc = (
        "# CLAUDE.md\n\n"
        "`agent-plugin`으로 생성된 파일입니다. 장기 수정은 `agent-plugins/roots/root.md`에서 관리하세요.\n\n"
        + claude_body
    )

    replace_file(project_root / "AGENTS.md", agents_doc, args.force)
    replace_file(project_root / ".claude" / "CLAUDE.md", claude_doc, args.force)

    skills_path = project_root / ".claude" / "SKILLS.md"
    if skills_path.is_symlink():
        skills_path.unlink()

    print(f"generated AGENTS.md and .claude/CLAUDE.md in {project_root}")


def install_codex_skill(args: argparse.Namespace) -> None:
    manifest_path = PLUGIN_HOME / "plugins" / "codex-skill" / args.skill_name / "plugin.yaml"
    if not manifest_path.exists():
        raise SystemExit(f"unknown codex skill plugin: {args.skill_name}")
    manifest = parse_manifest(manifest_path)
    source_path = (PLUGIN_HOME / manifest["source"]).resolve()
    target_path = Path(os.path.expanduser(manifest["target"]))
    target_path.parent.mkdir(parents=True, exist_ok=True)

    if target_path.exists() or target_path.is_symlink():
        if target_path.is_dir() and not target_path.is_symlink():
            shutil.rmtree(target_path)
        else:
            target_path.unlink()

    if args.mode == "copy":
        shutil.copytree(source_path, target_path)
        print(f"copied {args.skill_name} -> {target_path}")
        return

    target_path.symlink_to(source_path, target_is_directory=True)
    print(f"symlinked {args.skill_name} -> {target_path}")


def list_plugins(_: argparse.Namespace) -> None:
    root_manifest = parse_manifest(PLUGIN_HOME / "plugins" / "root" / "plugin.yaml")
    print(f"root\t{root_manifest['description']}")
    for manifest_path in sorted((PLUGIN_HOME / "plugins" / "codex-skill").glob("*/plugin.yaml")):
        manifest = parse_manifest(manifest_path)
        print(f"codex-skill:{manifest['name']}\t{manifest['description']}")


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="agent-plugin")
    subparsers = parser.add_subparsers(dest="command", required=True)

    list_parser = subparsers.add_parser("list", help="List available plugins")
    list_parser.set_defaults(func=list_plugins)

    install_parser = subparsers.add_parser("install", help="Install a plugin")
    install_subparsers = install_parser.add_subparsers(dest="plugin_type", required=True)

    root_parser = install_subparsers.add_parser("root", help="Generate AGENTS.md and .claude/CLAUDE.md")
    root_parser.add_argument("project_root")
    root_parser.add_argument("--project-name")
    root_parser.add_argument("--force", action="store_true")
    root_parser.set_defaults(func=install_root)

    skill_parser = install_subparsers.add_parser("codex-skill", help="Install a Codex skill plugin")
    skill_parser.add_argument("skill_name")
    skill_parser.add_argument("--mode", choices=("symlink", "copy"), default="symlink")
    skill_parser.set_defaults(func=install_codex_skill)

    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    args.func(args)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
